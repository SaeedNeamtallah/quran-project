{
  "manifest_version": 3,
  "name": "بومودورو قرآني",
  "description": "مؤقت بومودورو مع قراءة القرآن الكريم — يعمل بدون إنترنت",
  "version": "1.0.0",
  "permissions": ["storage", "alarms", "notifications"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "بومودورو قرآني"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["quran_offline.json", "alarm.m4a"],
      "matches": ["<all_urls>"]
    }
  ]
}
